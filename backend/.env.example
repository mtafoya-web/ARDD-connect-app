DATABASE_URL=sqlite:///./ardd.db
SECRET_KEY=replace-with-a-64-character-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:8000
MAX_UPLOAD_BYTES=10485760
GOOGLE_CLIENT_ID=
UPLOAD_ROOT=./uploads

# Optional. If omitted or left as placeholders, uploads fall back to local storage.
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Used by seed_admin.py.
ADMIN_EMAIL=admin@ardd.com
ADMIN_PASSWORD=replace-with-admin-password
